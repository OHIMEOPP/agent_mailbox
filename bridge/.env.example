# claude-mailbox / mailbox-bridge environment template.
#
# Copy to `.env` (`cp .env.example .env`) and fill in the secret.
# `.env` is gitignored; `.env.example` is committed as documentation.

# Discord bot token — paste the bot's token after the = sign (no quotes).
# Leaving empty disables bridge's /agent-notify endpoint (it returns 502
# no_token; node-red /agent-notify on :1901 keeps working regardless).
DISCORD_BOT_TOKEN=

# Default Discord DM channel id when /agent-notify request omits "channel".
# Default = trusted user (ohimeopp) DM channel.
DISCORD_DEFAULT_CHANNEL=1284065900659740773

# Bearer token for mailbox-server :1905 (REST/SSE endpoints for cross-device spokes).
# Generate once: py -c "import secrets; print(secrets.token_urlsafe(32))"
# Min 16 chars. Required when mailbox-server service is running; bridge ignores this.
CLAUDE_MAILBOX_TOKEN=
