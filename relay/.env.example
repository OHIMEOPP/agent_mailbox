# Phone-side shared secret. Pick something hard to guess.
#   openssl rand -hex 24
RELAY_TOKEN=replace-with-random-secret-from-openssl-rand-hex-24

# Hub IP reachable from this spoke. Examples:
#   100.64.5.7    (Tailscale)
#   26.10.20.30   (Radmin VPN)
#   192.168.1.50  (same-LAN)
HUB_VPN_IP=replace-with-hub-vpn-ip

# Hub mailbox-server port. Leave at 1905 unless you changed it.
HUB_PORT=1905

# Hub's CLAUDE_MAILBOX_TOKEN — same value your spoke uses to talk to hub
# (see the spoke MCP server's .mcp.json env). Required for /attachment/<id>
# (GET + DELETE).
HUB_TOKEN=replace-with-same-value-as-CLAUDE_MAILBOX_TOKEN

# Whose attachments /list shows. This is the mailbox `to_name` filter — usually
# the name this spoke's MCP server registers as (e.g. "wiki", "wiki@LAPTOP-XYZ").
MAILBOX_RECIPIENT=wiki

# Port this relay listens on (phone's URL uses this).
# Phones open: http://<spoke-ip>:<RELAY_PORT>/list?token=<RELAY_TOKEN>
RELAY_PORT=1906
