# mailbox-relay nginx config — streaming proxy from phone (hotspot LAN)
# to hub mailbox-server (over VPN). No file lands on this spoke's disk.
#
# Variables substituted at container start by envsubst (limited to vars
# matching NGINX_ENVSUBST_FILTER env, so nginx internals like $arg_token
# and $1 are NOT touched):
#   RELAY_TOKEN  — shared secret phone must include as ?token=...
#   HUB_VPN_IP   — hub IP reachable from this spoke over VPN (e.g. Tailscale 100.x.y.z)
#   HUB_PORT     — hub mailbox-server port (default 1905)
#   HUB_TOKEN    — Bearer token mailbox-server requires (= spoke's CLAUDE_MAILBOX_TOKEN)

server {
    listen 80 default_server;
    server_name _;

    # DNS resolver needed because proxy_pass below contains an nginx capture
    # variable (`$1`), which forces nginx into runtime DNS regardless of
    # whether HUB_VPN_IP itself is a hostname or a literal IP after envsubst.
    # 127.0.0.11 is Docker's embedded DNS; replace if running outside Docker.
    resolver 127.0.0.11 valid=30s ipv6=off;

    # Root returns 404 to avoid leaking product name / path hints to anyone
    # who happens to scan the hotspot. Legit users always hit /file/<id>?token.
    location = / {
        return 404;
    }

    # Liveness probe (used by docker healthcheck).
    location = /health {
        default_type text/plain;
        return 200 "ok\n";
    }

    # The actual streaming relay. Phone hits this with the attachment id.
    location ~ ^/file/([0-9]+)$ {
        # Don't log the ?token= query string — it's a shared secret. Default
        # access_log writes the full URI including args; if the spoke machine
        # is later seized / logs uploaded, the token would be exposed.
        # /health and other paths keep logging via the server-level default.
        access_log off;

        # Phone-side token check. Cheap defense against random hotspot guests.
        # For stronger auth, layer one-time tokens or TLS+client-cert.
        if ($arg_token != "${RELAY_TOKEN}") {
            return 403 "forbidden: missing or invalid ?token\n";
        }

        # Forward to hub's mailbox-server /attachment/<id> endpoint, injecting
        # the Bearer token hub requires. Hub sees a single trusted spoke
        # connection; phone never sees hub's token.
        proxy_pass http://${HUB_VPN_IP}:${HUB_PORT}/attachment/$1;
        proxy_set_header Authorization "Bearer ${HUB_TOKEN}";
        # Set Host to hub's address (not phone's $host), so any hub-side Host
        # validation passes and audit logs reflect the actual upstream.
        proxy_set_header Host "${HUB_VPN_IP}:${HUB_PORT}";
        proxy_set_header X-Forwarded-For $remote_addr;

        # Streaming: do NOT buffer the upstream response to disk.
        # Without these two off, nginx writes the full response to a temp file
        # in /var/cache/nginx/proxy_temp before serving — defeating the
        # whole point of "spoke doesn't store the file".
        proxy_buffering off;
        proxy_request_buffering off;

        # Large file friendly: don't time out mid-stream.
        proxy_read_timeout 1h;
        proxy_send_timeout 1h;
        proxy_connect_timeout 10s;

        # Range requests pass through automatically (nginx default), so
        # phone can resume interrupted downloads.
    }
}
